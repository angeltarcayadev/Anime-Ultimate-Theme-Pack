{
  "name": "anime-ultimate-theme-pack",
  "displayName": "Anime Theme Pack: Plus Ultra Edition",
  "version": "2.3.0",
  "publisher": "angeltarcayadev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/angeltarcayadev/Anime-Ultimate-Theme-Pack.git"
  },
  "description": "9 Stunning Anime Themes (Naruto, JJK, AoT, MHA, One Piece, and more) with immersive background images.",
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Themes"
  ],
  "main": "./out/deku-extension.js",
  "icon": "icon.png",
  "contributes": {
    "configuration": {
      "title": "Deku Pack Pro",
      "properties": {
        "dekuPack.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Habilitar/Deshabilitar el motor visual de fondos de Deku-Pack."
        },
        "dekuPack.customBackground": {
          "type": "string",
          "default": "",
          "description": "Ruta local o URL de imagen personalizada. Si se deja vacío, usará la imagen oficial del tema de Anime seleccionado."
        },
        "dekuPack.opacity": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Opacidad del fondo (0.0 a 1.0)."
        },
        "dekuPack.blur": {
          "type": "string",
          "default": "0px",
          "description": "Desenfoque (ej: 2px, 5px)."
        },
        "dekuPack.anchor": {
          "type": "string",
          "enum": [
            "center",
            "top",
            "bottom",
            "left",
            "right"
          ],
          "default": "center",
          "description": "Posición de la imagen."
        }
      }
    },
    "commands": [
      {
        "command": "deku-pack.install",
        "title": "Deku-Pack: Install Theme Assets",
        "category": "Deku-Pack"
      },
      {
        "command": "deku-pack.remove",
        "title": "Deku-Pack: Remove Theme Assets",
        "category": "Deku-Pack"
      },
      {
        "command": "deku-pack.select-theme",
        "title": "Deku-Pack: Select Anime Theme",
        "category": "Deku-Pack"
      }
    ],
    "themes": [
      {
        "label": "Deku-Pack: My Hero Academia",
        "uiTheme": "vs-dark",
        "path": "./themes/mha.json"
      },
      {
        "label": "Deku-Pack: Jujutsu Kaisen",
        "uiTheme": "vs-dark",
        "path": "./themes/jjk.json"
      },
      {
        "label": "Deku-Pack: Attack on Titan",
        "uiTheme": "vs-dark",
        "path": "./themes/aot.json"
      },
      {
        "label": "Deku-Pack: Demon Slayer",
        "uiTheme": "vs-dark",
        "path": "./themes/demon_slayer.json"
      },
      {
        "label": "Deku-Pack: One Piece",
        "uiTheme": "vs-dark",
        "path": "./themes/one_piece.json"
      },
      {
        "label": "Deku-Pack: Cyberpunk Night",
        "uiTheme": "vs-dark",
        "path": "./themes/cyberpunk.json"
      },
      {
        "label": "Deku-Pack: Naruto Hokage",
        "uiTheme": "vs-dark",
        "path": "./themes/naruto.json"
      },
      {
        "label": "Deku-Pack: Akira Neo Tokyo",
        "uiTheme": "vs-dark",
        "path": "./themes/akira.json"
      },
      {
        "label": "Deku-Pack: Anime Classics",
        "uiTheme": "vs-dark",
        "path": "./themes/classics.json"
      }
    ],
    "configurationDefaults": {
      "editor.cursorBlinking": "expand",
      "editor.cursorSmoothCaretAnimation": "on",
      "editor.fontLigatures": true,
      "editor.minimap.enabled": false,
      "workbench.list.smoothScrolling": true,
      "terminal.integrated.gpuAcceleration": "on"
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}
